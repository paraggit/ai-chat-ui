# Hugging Face API token (optional if set in the UI)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# Model ID on Hugging Face Hub
# Examples: mistralai/Mistral-7B-Instruct-v0.2, meta-llama/Llama-2-7b-chat-hf
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Request timeout in milliseconds (10–20s recommended)
HF_TIMEOUT_MS=15000

# Vision model for image uploads (optional)
HF_VISION_MODEL=Salesforce/blip-vqa-base

# Text-to-image model for generated responses (optional)
HF_IMAGE_GEN_MODEL=stabilityai/stable-diffusion-2-1

# Custom Inference Endpoint base URL (optional)
# Example: https://abc123.us-east-1.aws.endpoints.huggingface.cloud
# HF_API_BASE=https://your-endpoint.aws.endpoints.huggingface.cloud

# Server
PORT=3001
NODE_ENV=development

# Self-signed SSL (optional)
# Generate certs: npm run certs:generate
# SSL_ENABLED=true
# SSL_KEY_PATH=./certs/key.pem
# SSL_CERT_PATH=./certs/cert.pem

# Allowed frontend origin (CORS)
# HTTP:  CLIENT_ORIGIN=http://localhost:5173
# HTTPS: CLIENT_ORIGIN=https://localhost:5173
CLIENT_ORIGIN=http://localhost:5173
